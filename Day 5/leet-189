class Solution {
private void reverse(int s,int e,int[]arr){
    while(s<e){
        int temp=arr[s];
        arr[s++]=arr[e];
         arr[e--]=temp;
    }
}

    public void rotate(int[] nums, int k) {
        k%=nums.length;
        reverse(0,nums.length-1,nums);
        reverse(0,k-1,nums);
        reverse(k,nums.length-1,nums);
    }
}
